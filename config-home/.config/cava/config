[general]
bars = 32
framerate = 60
sensitivity = 150
autosens = 1
lower_cutoff_freq = 50
higher_cutoff_freq = 10000

[input]
method = pulse
source = auto

[output]
method = ncurses
channels = stereo
mono_option = average
reverse = 0
raw_target = /dev/stdout
data_format = ascii
ascii_max_range = 7

[color]
gradient = 1
gradient_count = 4
gradient_color_1 = '#7aa2f7'
gradient_color_2 = '#89dceb'
gradient_color_3 = '#a6da95'
gradient_color_4 = '#f5c2e7'

[smoothing]
integral = 65
monstercat = 1
noise_reduction = 0.60
