#!/usr/bin/env python3

import tempfile
import tomllib
from pathlib import Path
from subprocess import run


THEME_FILE = Path.home() / ".config/omarchy/current/theme/colors.toml"


def read_theme() -> dict:
    try:
        return tomllib.loads(THEME_FILE.read_text())
    except Exception:
        return {}


def pick(theme: dict, key: str, fallback: str) -> str:
    return theme.get(key, fallback)


def main() -> int:
    theme = read_theme()
    config = f"""[general]
bars = 48
bar_width = 2
bar_spacing = 1
center_align = 1
framerate = 75
sensitivity = 180
autosens = 1
lower_cutoff_freq = 50
higher_cutoff_freq = 10000

[input]
method = pulse
source = auto

[output]
method = ncurses
channels = stereo
mono_option = average
reverse = 0
waveform = 0
data_format = ascii
ascii_max_range = 7

[color]
gradient = 1
gradient_count = 6
gradient_color_1 = '{pick(theme, "accent", "#7fbbb3")}'
gradient_color_2 = '{pick(theme, "color12", "#7fbbb3")}'
gradient_color_3 = '{pick(theme, "color14", "#83c092")}'
gradient_color_4 = '{pick(theme, "color10", "#a7c080")}'
gradient_color_5 = '{pick(theme, "color11", "#dbbc7f")}'
gradient_color_6 = '{pick(theme, "color13", "#d699b6")}'

[smoothing]
integral = 72
monstercat = 1
noise_reduction = 0.72
"""

    with tempfile.NamedTemporaryFile("w", delete=False, prefix="music-control-room-cava-", suffix=".conf") as tmp:
        tmp.write(config)
        tmp_path = tmp.name

    return run(["cava", "-p", tmp_path], check=False).returncode


if __name__ == "__main__":
    raise SystemExit(main())
