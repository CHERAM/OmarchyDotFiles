#!/usr/bin/env python3

import json
import mimetypes
import re
import subprocess
import tomllib
import urllib.parse
import urllib.request
from http import HTTPStatus
from http.server import SimpleHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path


ROOT = Path.home() / ".local/share/music-control-room"
HOST = "127.0.0.1"
PORT = 8976
SEARCH_URL = "https://lrclib.net/api/search"
SYNC_PATTERN = re.compile(r"^\[(\d+):(\d+(?:\.\d+)?)\](.*)$")
LYRICS_CACHE: dict[tuple[str, str], dict] = {}
THEME_FILE = Path.home() / ".config/omarchy/current/theme/colors.toml"


def run_playerctl(*args: str) -> str:
    result = subprocess.run(
        ["playerctl", "-p", "spotify", *args],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        return ""
    return result.stdout.strip()


def now_playing() -> dict:
    status = run_playerctl("status")
    if not status:
        return {"active": False}

    position = run_playerctl("position")
    length_usec = run_playerctl("metadata", "mpris:length")
    volume = run_playerctl("volume")

    try:
        length_seconds = int(length_usec) / 1_000_000 if length_usec else 0
    except ValueError:
        length_seconds = 0

    try:
        position_seconds = float(position) if position else 0
    except ValueError:
        position_seconds = 0

    try:
        volume_percent = round(float(volume) * 100) if volume else 0
    except ValueError:
        volume_percent = 0

    return {
        "active": True,
        "status": status,
        "title": run_playerctl("metadata", "xesam:title"),
        "artist": run_playerctl("metadata", "xesam:artist"),
        "album": run_playerctl("metadata", "xesam:album"),
        "artUrl": run_playerctl("metadata", "mpris:artUrl"),
        "position": position_seconds,
        "length": length_seconds,
        "volume": volume_percent,
    }


def theme_colors() -> dict:
    try:
        return tomllib.loads(THEME_FILE.read_text())
    except Exception:
        return {
            "accent": "#7fbbb3",
            "foreground": "#d3c6aa",
            "background": "#2d353b",
            "color0": "#475258",
            "color8": "#475258",
            "color10": "#a7c080",
            "color11": "#dbbc7f",
            "color12": "#7fbbb3",
            "color13": "#d699b6",
            "color14": "#83c092",
        }


def fetch_lyrics(track: dict) -> dict:
    if not track.get("active"):
        return {"active": False, "lines": [], "mode": "offline"}

    key = (track.get("artist", ""), track.get("title", ""))
    if key not in LYRICS_CACHE:
        params = urllib.parse.urlencode(
            {"track_name": track.get("title", ""), "artist_name": track.get("artist", "")}
        )
        try:
            with urllib.request.urlopen(f"{SEARCH_URL}?{params}", timeout=8) as response:
                payload = json.loads(response.read().decode("utf-8"))
        except Exception:
            payload = []

        if payload:
            best = payload[0]
            LYRICS_CACHE[key] = {
                "plain": (best.get("plainLyrics") or "").strip(),
                "synced": (best.get("syncedLyrics") or "").strip(),
            }
        else:
            LYRICS_CACHE[key] = {"plain": "", "synced": ""}

    cached = LYRICS_CACHE[key]
    synced = cached.get("synced", "")
    if synced:
        rows = []
        for raw_line in synced.splitlines():
            match = SYNC_PATTERN.match(raw_line)
            if not match:
                continue
            minutes, seconds, lyric = match.groups()
            rows.append((int(minutes) * 60 + float(seconds), (lyric.strip() or "...")))

        current = 0
        for idx, (timestamp, _) in enumerate(rows):
            if timestamp <= track.get("position", 0):
                current = idx
            else:
                break

        start = max(0, current - 2)
        end = min(len(rows), current + 4)
        lines = [{"text": rows[idx][1], "active": idx == current} for idx in range(start, end)]
        return {"active": True, "mode": "synced", "lines": lines}

    plain_lines = [line.strip() for line in cached.get("plain", "").splitlines() if line.strip()]
    if not plain_lines:
        return {"active": True, "mode": "missing", "lines": [{"text": "Lyrics not found for this track.", "active": True}]}

    visible = plain_lines[:6]
    lines = [{"text": text, "active": False} for text in visible]
    return {"active": True, "mode": "plain", "lines": lines}


class Handler(SimpleHTTPRequestHandler):
    def __init__(self, *args, **kwargs):
        super().__init__(*args, directory=str(ROOT), **kwargs)

    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)
        if parsed.path == "/api/now-playing":
            payload = json.dumps(now_playing()).encode("utf-8")
            self.send_response(HTTPStatus.OK)
            self.send_header("Content-Type", "application/json; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(payload)))
            self.end_headers()
            self.wfile.write(payload)
            return

        if parsed.path == "/api/theme":
            payload = json.dumps(theme_colors()).encode("utf-8")
            self.send_response(HTTPStatus.OK)
            self.send_header("Content-Type", "application/json; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(payload)))
            self.end_headers()
            self.wfile.write(payload)
            return

        if parsed.path == "/api/lyrics":
            payload = json.dumps(fetch_lyrics(now_playing())).encode("utf-8")
            self.send_response(HTTPStatus.OK)
            self.send_header("Content-Type", "application/json; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(payload)))
            self.end_headers()
            self.wfile.write(payload)
            return

        if parsed.path == "/art":
            info = now_playing()
            art_url = info.get("artUrl", "")
            if not art_url:
                self.send_error(HTTPStatus.NOT_FOUND)
                return

            try:
                if art_url.startswith("file://"):
                    art_path = Path(urllib.request.url2pathname(urllib.parse.urlparse(art_url).path))
                    data = art_path.read_bytes()
                    content_type = mimetypes.guess_type(art_path.name)[0] or "application/octet-stream"
                else:
                    with urllib.request.urlopen(art_url, timeout=5) as response:
                        data = response.read()
                        content_type = response.headers.get_content_type()
            except Exception:
                self.send_error(HTTPStatus.BAD_GATEWAY)
                return

            self.send_response(HTTPStatus.OK)
            self.send_header("Content-Type", content_type)
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(data)))
            self.end_headers()
            self.wfile.write(data)
            return

        if parsed.path == "/":
            self.path = "/index.html"
        elif parsed.path == "/lyrics":
            self.path = "/lyrics.html"

        return super().do_GET()

    def log_message(self, fmt: str, *args):
        return


def main():
    server = ThreadingHTTPServer((HOST, PORT), Handler)
    server.serve_forever()


if __name__ == "__main__":
    main()
